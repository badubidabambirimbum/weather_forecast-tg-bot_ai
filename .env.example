# Окружение conda (Python 3.11): из корня репозитория —
#   conda env create -f environment.yml && conda activate weather-bot
# Запуск: скопируйте этот файл в .env, заполните ключи, из корня репозитория: python main.py

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# --- Mini App (веб-форма в Telegram) ---
# Telegram открывает страницу только по публичному HTTPS. Локально это делают через туннель к вашему uvicorn.
#
# Команды ngrok / cloudflared сработают только после установки одной из программ (иначе PowerShell пишет «не распознано»).
# Установка в Windows, варианты:
#   winget install Ngrok.Ngrok
#   winget install Cloudflare.cloudflared
# Либо скачайте установщик с https://ngrok.com/download или https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/
# После установки закройте терминал и откройте снова (чтобы обновился PATH).
#
# ngrok без регистрации не запускает туннель (ошибка ERR_NGROK_4018 / «requires a verified account and authtoken»).
# Один раз: регистрация https://dashboard.ngrok.com/signup → токен в https://dashboard.ngrok.com/get-started/your-authtoken
# Затем в терминале:  ngrok config add-authtoken ВАШ_ТОКЕН
#
# 1) В .env задайте токены выше и PUBLIC_BASE_URL (без слэша в конце) — это HTTPS-адрес, который выдаст туннель.
# 2) Запустите приложение: python main.py  (по умолчанию HTTP на 0.0.0.0:8000)
# 3) В другом терминале поднимите туннель на тот же порт, что и PORT ниже (по умолчанию 8000), например:
#      ngrok http 8000
#    или:
#      cloudflared tunnel --url http://127.0.0.1:8000
#    Если в логах таймаут QUIC / DNS (failed to dial quic, lookup region1.v2.argotunnel.com timeout), попробуйте:
#      cloudflared tunnel --url http://127.0.0.1:8000 --protocol http2
#    Сообщения про cert.pem и config.yml при «quick tunnel» часто не мешают; главное — чтобы в конце пошли INF «Connection established» без повторяющихся ERR.
#    Если не помогает: другая сеть (раздача с телефона), другой DNS, отключение VPN/фильтра, либо ngrok вместо cloudflared.
# Без установки туннелей: при наличии Node.js можно  npx localtunnel --port 8000  (возьмите выданный https URL).
# У localtunnel часто показывается страница «To continue, enter the IP shown above» — в браузере введите указанный IP и продолжите.
# В Telegram Mini App это неудобно или не работает; для Mini App лучше ngrok (с authtoken) или облачный деплой, а не localtunnel.
# 4) Скопируйте выданный https://... в PUBLIC_BASE_URL и перезапустите python main.py.
# 5) В Telegram: /start у бота → кнопка «Прогноз на 5 дней» откроет Mini App.
#
# Если PUBLIC_BASE_URL пустой — бот работает только из чата (название города текстом), без кнопки Mini App.
# Для отладки страницы в обычном браузере без Telegram можно выставить ALLOW_UNVERIFIED_MINI_APP=1 (не для продакшена).
PUBLIC_BASE_URL=
# HOST=0.0.0.0
# PORT=8000
# ALLOW_UNVERIFIED_MINI_APP=0
